<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:PlSqlMergeTool.UI.ViewModels"
        xmlns:views="using:PlSqlMergeTool.UI.Views"
        xmlns:items="using:PlSqlMergeTool.UI.ViewModels.Items"
        xmlns:AvaloniaEdit="clr-namespace:AvaloniaEdit;assembly=AvaloniaEdit"
        xmlns:converters="using:Avalonia.Data.Converters"
        x:Class="PlSqlMergeTool.UI.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Title="Oracle PL/SQL Merge Tool"
        Width="1600" Height="900"
        Background="#1E1E1E">

    <Grid RowDefinitions="Auto, *, Auto">

        <!-- Settings Overlay -->
        <Panel Grid.RowSpan="3"
               IsVisible="{Binding IsSettingsOpen}"
               Background="#CC000000"
               ZIndex="1000">
            <ContentControl Content="{Binding CurrentSettingsVM}"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                <ContentControl.ContentTemplate>
                    <DataTemplate>
                        <views:SettingsView />
                    </DataTemplate>
                </ContentControl.ContentTemplate>
            </ContentControl>
        </Panel>

        <!-- Toolbar -->
        <Border Grid.Row="0" Classes="toolbar">
            <Grid ColumnDefinitions="Auto, *, Auto" Margin="8,4">
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8">
                    <Button Command="{Binding LoadWorkspaceCommand}"
                            Content="📁 Загрузить"
                            ToolTip.Tip="Анализировать рабочее пространство" />
                    <Button Command="{Binding CompilePackageCommand}"
                            Content="▶ Компилировать"
                            Classes="accent"
                            ToolTip.Tip="Скомпилировать выбранный пакет" />
                    <Border Width="1" Background="#3E3E42" Margin="4,0"/>
                    <Button Command="{Binding OpenSettingsCommand}"
                            Content="⚙"
                            Classes="secondary"
                            ToolTip.Tip="Настройки подключений" />
                </StackPanel>

                <TextBlock Grid.Column="1"
                           Text="{Binding SelectedPackage.Name}"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Center"
                           FontWeight="SemiBold"
                           FontSize="13"
                           Foreground="#CCCCCC" />

                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8">
                    <ProgressBar IsIndeterminate="True"
                                 IsVisible="{Binding IsLoading}"
                                 Width="120" Height="4"
                                 VerticalAlignment="Center" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main Content -->
        <Grid Grid.Row="1" ColumnDefinitions="300, 4, *">

            <!-- Sidebar -->
            <Border Grid.Column="0" Classes="sidebar" BorderThickness="0,0,1,0">
                <Grid RowDefinitions="Auto, *, 4, 1.5*" Margin="8">

                    <!-- Workspace Info -->
                    <Border Grid.Row="0"
                            Background="#2D2D30"
                            BorderBrush="#3E3E42"
                            BorderThickness="1"
                            CornerRadius="3"
                            Padding="8"
                            Margin="0,0,0,8">
                        <StackPanel Spacing="4">
                            <TextBlock Text="Рабочее пространство"
                                       Classes="header"
                                       FontSize="11"/>
                            <TextBlock Text="{Binding StatusMessage}"
                                       TextWrapping="Wrap"
                                       FontSize="11"
                                       Classes="muted" />
                        </StackPanel>
                    </Border>

                    <!-- DDL Changes Panel -->
                    <HeaderedContentControl Grid.Row="1" Header="DDL Изменения">
                        <Grid>
                            <!-- DDL Changes List -->
                            <ScrollViewer IsVisible="{Binding DdlChanges.Count, Converter={x:Static converters:ObjectConverters.IsNotNull}}"
                                          Background="#1E1E1E">
                                <ItemsControl ItemsSource="{Binding DdlChanges}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="items:DdlChangeItemViewModel">
                                            <Border Background="#252526"
                                                    BorderBrush="#3E3E42"
                                                    BorderThickness="0,0,0,1"
                                                    Padding="8,6">
                                                <StackPanel Spacing="4">
                                                    <!-- Object Header -->
                                                    <Grid ColumnDefinitions="Auto, *, Auto">
                                                        <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="6">
                                                            <TextBlock Text="{Binding Icon}" FontSize="12" VerticalAlignment="Center"/>
                                                            <TextBlock Text="{Binding DisplayText}"
                                                                       FontWeight="SemiBold"
                                                                       FontSize="11"
                                                                       VerticalAlignment="Center"/>
                                                        </StackPanel>

                                                        <Border Grid.Column="2"
                                                                Background="{Binding SourceColor}"
                                                                CornerRadius="2"
                                                                Padding="4,2"
                                                                IsVisible="{Binding Source, Converter={x:Static converters:ObjectConverters.IsNotNull}}">
                                                            <TextBlock Text="{Binding SourceText}"
                                                                       FontSize="9"
                                                                       FontWeight="Bold"
                                                                       Foreground="White"/>
                                                        </Border>
                                                    </Grid>

                                                    <!-- Summary -->
                                                    <TextBlock Text="{Binding Summary}"
                                                               FontSize="10"
                                                               Classes="muted"
                                                               Margin="18,0,0,0"/>

                                                    <!-- Column Changes -->
                                                    <ItemsControl ItemsSource="{Binding ColumnChanges}"
                                                                  Margin="18,4,0,0"
                                                                  IsVisible="{Binding ColumnChanges.Count, Converter={x:Static converters:ObjectConverters.IsNotNull}}">
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate x:DataType="items:ColumnChangeItemViewModel">
                                                                <Border Background="#2D2D30"
                                                                        CornerRadius="2"
                                                                        Padding="6,4"
                                                                        Margin="0,2">
                                                                    <Grid RowDefinitions="Auto, Auto">
                                                                        <!-- Column Name -->
                                                                        <Grid Grid.Row="0" ColumnDefinitions="Auto, *, Auto">
                                                                            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="4">
                                                                                <TextBlock Text="{Binding Icon}" FontSize="10"/>
                                                                                <TextBlock Text="{Binding ColumnName}"
                                                                                           FontFamily="Cascadia Code,Consolas"
                                                                                           FontSize="10"
                                                                                           FontWeight="SemiBold"/>
                                                                            </StackPanel>

                                                                            <Border Grid.Column="2"
                                                                                    Background="{Binding SourceColor}"
                                                                                    CornerRadius="2"
                                                                                    Padding="3,1">
                                                                                <TextBlock Text="{Binding SourceText}"
                                                                                           FontSize="8"
                                                                                           FontWeight="Bold"
                                                                                           Foreground="White"/>
                                                                            </Border>
                                                                        </Grid>

                                                                        <!-- Column Details -->
                                                                        <TextBlock Grid.Row="1"
                                                                                   Text="{Binding DetailedInfo}"
                                                                                   FontSize="9"
                                                                                   Classes="muted"
                                                                                   Margin="14,2,0,0"
                                                                                   TextWrapping="Wrap"/>
                                                                    </Grid>
                                                                </Border>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>

                            <!-- Empty State -->
                            <Border IsVisible="{Binding DdlChanges.Count, Converter={x:Static converters:ObjectConverters.IsNull}}"
                                    Background="#1E1E1E"
                                    Padding="8">
                                <TextBlock Text="Нет DDL изменений"
                                           Classes="muted"
                                           FontSize="11"
                                           TextWrapping="Wrap"
                                           VerticalAlignment="Center"
                                           HorizontalAlignment="Center"
                                           TextAlignment="Center" />
                            </Border>
                        </Grid>
                    </HeaderedContentControl>

                    <GridSplitter Grid.Row="2" ResizeDirection="Rows" />

                    <!-- Packages Panel -->
                    <HeaderedContentControl Grid.Row="3" Header="Пакеты PL/SQL">
                        <ListBox ItemsSource="{Binding Packages}"
                                 SelectedItem="{Binding SelectedPackage}"
                                 Background="#1E1E1E">
                            <ListBox.ItemTemplate>
                                <DataTemplate x:DataType="items:PackageItemViewModel">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <TextBlock Text="{Binding StatusIcon}" FontSize="14" />
                                        <TextBlock Text="{Binding Name}"
                                                   VerticalAlignment="Center"
                                                   FontSize="12" />
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </HeaderedContentControl>
                </Grid>
            </Border>

            <GridSplitter Grid.Column="1" ResizeDirection="Columns" />

            <!-- Editor Area -->
            <Grid Grid.Column="2">
                <!-- Editors -->
                <Grid IsVisible="{Binding SelectedPackage, Converter={x:Static converters:ObjectConverters.IsNotNull}}"
                      RowDefinitions="Auto, *"
                      ColumnDefinitions="*, 2, *, 2, *">

                    <!-- Editor Headers -->
                    <Border Grid.Row="0" Grid.Column="0" Classes="editor-header local" BorderThickness="0,0,0,1">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock Text="🏦" FontSize="14" VerticalAlignment="Center"/>
                            <TextBlock Text="LOCAL (Банк)" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="0" Grid.Column="2" Classes="editor-header resolved" BorderThickness="0,0,0,1">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock Text="✓" FontSize="14" VerticalAlignment="Center" Foreground="#4EC9B0"/>
                            <TextBlock Text="RESOLVED (Итоговый код)" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="0" Grid.Column="4" Classes="editor-header target" BorderThickness="0,0,0,1">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock Text="🏢" FontSize="14" VerticalAlignment="Center"/>
                            <TextBlock Text="TARGET (Вендор)" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <!-- Editors -->
                    <Border Grid.Row="1" Grid.Column="0" Classes="editor-container">
                        <AvaloniaEdit:TextEditor Name="LocalEditor"
                                               IsReadOnly="True"
                                               ShowLineNumbers="True"
                                               FontFamily="Cascadia Code,Consolas,Courier New"
                                               FontSize="13"
                                               Background="#1E1E1E"
                                               Foreground="#D4D4D4"
                                               LineNumbersForeground="#858585" />
                    </Border>

                    <GridSplitter Grid.Row="1" Grid.Column="1" ResizeDirection="Columns" />

                    <Border Grid.Row="1" Grid.Column="2" Classes="editor-container">
                        <AvaloniaEdit:TextEditor Name="ResolvedEditor"
                                               ShowLineNumbers="True"
                                               FontFamily="Cascadia Code,Consolas,Courier New"
                                               FontSize="13"
                                               Background="#1E1E1E"
                                               Foreground="#D4D4D4"
                                               LineNumbersForeground="#858585" />
                    </Border>

                    <GridSplitter Grid.Row="1" Grid.Column="3" ResizeDirection="Columns" />

                    <Border Grid.Row="1" Grid.Column="4" Classes="editor-container">
                        <AvaloniaEdit:TextEditor Name="TargetEditor"
                                               IsReadOnly="True"
                                               ShowLineNumbers="True"
                                               FontFamily="Cascadia Code,Consolas,Courier New"
                                               FontSize="13"
                                               Background="#1E1E1E"
                                               Foreground="#D4D4D4"
                                               LineNumbersForeground="#858585" />
                    </Border>
                </Grid>

                <!-- Empty State -->
                <StackPanel IsVisible="{Binding SelectedPackage, Converter={x:Static converters:ObjectConverters.IsNull}}"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Center"
                            Spacing="16">
                    <TextBlock Text="📂" FontSize="64" HorizontalAlignment="Center" Opacity="0.3"/>
                    <TextBlock Text="Выберите пакет из списка слева"
                               FontSize="16"
                               Classes="muted"
                               HorizontalAlignment="Center" />
                    <TextBlock Text="или нажмите 'Загрузить' для анализа рабочего пространства"
                               FontSize="13"
                               Classes="muted"
                               HorizontalAlignment="Center" />
                </StackPanel>
            </Grid>
        </Grid>

        <!-- Status Bar -->
        <Border Grid.Row="2" Classes="statusbar">
            <Grid ColumnDefinitions="Auto, *, Auto">
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="12">
                    <TextBlock Text="{Binding StatusMessage}"
                               Foreground="White"
                               FontSize="11"
                               VerticalAlignment="Center" />
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="16">
                    <TextBlock VerticalAlignment="Center" Foreground="White" FontSize="11">
                        <Run Text="Пакетов: "/>
                        <Run Text="{Binding Packages.Count}" FontWeight="Bold"/>
                    </TextBlock>
                    <TextBlock Text="Oracle PL/SQL Merge Tool v1.0"
                               Foreground="White"
                               FontSize="11"
                               Opacity="0.8"
                               VerticalAlignment="Center" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
