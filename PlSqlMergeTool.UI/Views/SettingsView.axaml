<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:PlSqlMergeTool.UI.ViewModels"
             x:Class="PlSqlMergeTool.UI.Views.SettingsView"
             x:DataType="vm:SettingsViewModel">
    <Border Background="White"
            CornerRadius="8"
            Padding="20"
            MinWidth="500"
            MaxWidth="600"
            BoxShadow="0 10 30 0 #60000000"
            BorderBrush="#D0D0D0"
            BorderThickness="1">
        <StackPanel Spacing="15">
            <TextBlock Text="Настройки подключений" FontSize="20" FontWeight="Bold" Margin="0,0,0,10"/>

            <StackPanel Spacing="5">
                <TextBlock Text="Baseline (Эталон) Oracle Connection:" Foreground="Gray" FontSize="12"/>
                <TextBox Text="{Binding BaselineConnection}" PlaceholderText="User Id=...;Password=...;Data Source=..."/>
            </StackPanel>

            <StackPanel Spacing="5">
                <TextBlock Text="Local (Банк) Oracle Connection:" Foreground="Gray" FontSize="12"/>
                <TextBox Text="{Binding LocalConnection}" PlaceholderText="User Id=...;Password=...;Data Source=..."/>
            </StackPanel>

            <StackPanel Spacing="5">
                <TextBlock Text="Target (Вендор) Oracle Connection:" Foreground="Gray" FontSize="12"/>
                <TextBox Text="{Binding TargetConnection}" PlaceholderText="User Id=...;Password=...;Data Source=..."/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="10" Margin="0,15,0,0">
                <Button Content="Отмена"
                        Command="{Binding CloseCommand}"
                        Width="100"/>
                <Button Content="Сохранить" Classes="accent"
                        Command="{Binding SaveCommand}"
                        Width="100"/>
            </StackPanel>
        </StackPanel>
    </Border>
</UserControl>
